{
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/pages/menu",
      "destination": "/pages/menu/index.html"
    },
    {
      "source": "/pages/products",
      "destination": "/pages/products/index.html"
    },
    {
      "source": "/pages/sellers",
      "destination": "/pages/sellers/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
